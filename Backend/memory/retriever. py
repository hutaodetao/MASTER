"""
记忆检索器 - 智能检索+上下文注入
"""
from dataclasses import dataclass, field
from typing import Any
from .provider import MemoryProvider, SearchMemoryRequest, MemorySearchResult
from .extractor import ExtractedFacts
 
 
@dataclass
class RetrievalContext:
    """检索上下文"""
    query: str
    memories: list  # 记忆内容列表
    metadata: dict = field(default_factory=dict)  # 额外元数据
    
    def to_prompt_context(self) -> str:
        """转换为 prompt 上下文格式"""
        if not self.memories:
            return ""
        
        context_parts = ["## 相关记忆\n"]
        
        for i, mem in enumerate(self.memories, 1):
            content = mem.get("content", "") if isinstance(mem, dict) else str(mem)
            context_parts.append(f"**记忆 {i}**: {content}")
        
        return "\n".join(context_parts)
    
    def to_messages_format(self) -> list[dict]:
        """转换为消息格式（用于 LLM）"""
        if not self.memories:
            return []
        
        messages = []
        for mem in self.memories:
            content = mem.get("content", "") if isinstance(mem, dict) else str(mem)
            messages.append({
                "role": "system",
                "content": f"记忆: {content}",
            })
        
        return messages
 
 
class MemoryRetriever:
    """记忆检索器 - 负责检索 + 上下文注入"""
    
    def __init__(
        self,
        provider: MemoryProvider,
        max_context_memories: int = 5,
        min_similarity: float = 0.3,
    ):
        self.provider = provider
        self.max_context_memories = max_context_memories
        self.min_similarity = min_similarity
    
    async def retrieve(
        self,
        bot_id: str,
        query: str,
        filters: dict | None = None,
    ) -> RetrievalContext:
        """
        检索相关记忆
        
        Args:
            bot_id: 机器人 ID
            query: 查询文本
            filters: 过滤条件
            
        Returns:
            RetrievalContext: 检索上下文
        """
        result = await self.provider.search(
            SearchMemoryRequest(
                bot_id=bot_id,
                query=query,
                limit=self.max_context_memories,
                filters=filters,
            )
        )
        
        # 过滤低相似度结果
        filtered_items = []
        for i, item in enumerate(result.items):
            score = result.scores[i] if i < len(result.scores) else 0
            if score >= self.min_similarity:
                filtered_items.append({
                    "id": item.id,
                    "content": item.content,
                    "metadata": item.metadata,
                    "score": score,
                })
        
        return RetrievalContext(
            query=query,
            memories=filtered_items,
            metadata={"total_found": result.total},
        )
    
    async def inject_context(
        self,
        bot_id: str,
        current_prompt: str,
        query: str,
    ) -> str:
        """
        将记忆注入到 prompt 中
        
        Args:
            bot_id: 机器人 ID
            current_prompt: 当前 prompt
            query: 当前查询
            
        Returns:
            str: 注入记忆后的新 prompt
        """
        context = await self.retrieve(bot_id, query)
        
        if not context.memories:
            return current_prompt
        
        # 构建新 prompt
        memory_context = context.to_prompt_context()
        
        injected_prompt = f"""{current_prompt}

{memory_context}

---
*上述记忆来自之前的任务，请参考并在回答中体现一致性。*"""
        
        return injected_prompt
    
    async def inject_as_system_message(
        self,
        bot_id: str,
        query: str,
        system_prompt: str = "",
    ) -> list[dict]:
        """
        注入记忆作为系统消息
        
        Args:
            bot_id: 机器人 ID
            query: 用户查询
            system_prompt: 现有系统 prompt
            
        Returns:
            list[dict]: 消息列表，可直接传给 LLM
        """
        context = await self.retrieve(bot_id, query)
        
        messages = []
        
        # 系统消息
        if system_prompt:
            messages.append({"role": "system", "content": system_prompt})
        
        # 记忆消息
        memory_messages = context.to_messages_format()
        messages.extend(memory_messages)
        
        # 用户消息
        messages.append({"role": "user", "content": query})
        
        return messages
    
    async def get_memory_summary(self, bot_id: str) -> str:
        """获取机器人记忆摘要"""
        result = await self.provider.get_all(bot_id, limit=10)
        
        if not result.items:
            return "暂无记忆"
        
        summaries = []
        for item in result.items:
            content = item.content[:100] + "..." if len(item.content) > 100 else item.content
            summaries.append(f"- {content}")
        
        return f"共 {result.total} 条记忆:\n" + "\n".join(summaries)
    
    async def search_and_format(
        self,
        bot_id: str,
        query: str,
        format_style: str = "markdown",
    ) -> str:
        """
        搜索并格式化结果
        
        Args:
            bot_id: 机器人 ID
            query: 查询
            format_style: 格式风格 (markdown / json / text)
            
        Returns:
            str: 格式化后的结果
        """
        context = await self.retrieve(bot_id, query)
        
        if not context.memories:
            return "未找到相关记忆"
        
        if format_style == "markdown":
            lines = [f"## 相关记忆 (找到 {len(context.memories)} 条)\n"]
            for mem in context.memories:
                score = mem.get("score", 0)
                lines.append(f"- [{score:.2f}] {mem['content']}")
            return "\n".join(lines)
        
        elif format_style == "json":
            import json
            return json.dumps(context.memories, ensure_ascii=False, indent=2)
        
        else:
            return "\n".join([mem["content"] for mem in context.memories])