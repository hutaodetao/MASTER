class EmailAdapter(ChannelAdapter):
    """Email 适配器 - 支持 SMTP 发送"""
    
    def __init__(self, config: ChannelConfig):
        self.config = config
        self.smtp_host = config.metadata.get("smtp_host", "smtp.gmail.com")
        self.smtp_port = config.metadata.get("smtp_port", 587)
        self.smtp_user = config.api_key or ""
        self.smtp_password = config.api_secret or ""  # 或 App Password
        self.from_email = config.metadata.get("from_email", self.smtp_user)
        self.use_tls = config.metadata.get("use_tls", True)
        
        # 收件处理
        self._webhook_parser = EmailWebhookParser()
    
    @property
    def channel_type(self) -> ChannelType:
        return ChannelType.EMAIL
    
    async def initialize(self, config: ChannelConfig) -> bool:
        """初始化 - 验证 SMTP 连接"""
        try:
            server = smtplib.SMTP(self.smtp_host, self.smtp_port) if self.smtp_port != 465 else smtplib.SMTP_SSL(self.smtp_host, self.smtp_port)
            
            if self.use_tls and self.smtp_port != 465:
                server.starttls()
            
            server.login(self.smtp_user, self.smtp_password)
            server.quit()
            return True
        except Exception as e:
            print(f"Email init error: {e}")
            return False
    
    def _build_message(
        self,
        to_email: str,
        subject: str,
        content: str,
        message_typ: MessageType = MessageType.TEXT,
    ) -> MIMEMultipart:
        """构建邮件"""
        msg = MIMEMultipart("alternative")
        msg["From"] = self.from_email
        msg["To"] = to_email
        msg["Subject"] = subject
        
        # 添加纯文本版本
        text_part = MIMEText(content, "plain", "utf-8")
        msg.attach(text_part)
        
        # 添加 HTML 版本（如果需要）
        if message_typ == MessageType.TEXT:
            # 简单转义 HTML
            html_content = content.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
            html_part = MIMEText(html_content, "html", "utf-8")
            msg.attach(html_part)
        
        return msg
    
    async def send_message(self, user_id: str, message: OutgoingMessage) -> str | None:
        """发送邮件"""
        try:
            # user_id 是邮箱地址
            subject = message.metadata.get("subject", "来自 M. A. S. T. E. R. 的消息")
            
            msg = self._build_message(user_id, subject, message.content, message.message_type)
            
            # 连接发送
            if self.smtp_port == 465:
                server = smtplib.SMTP_SSL(self.smtp_host, self.smtp_port)
            else:
                server = smtplib.SMTP(self.smtp_host, self.smtp_port)
                if self.use_tls:
                    server.starttls()
            
            server.login(self.smtp_user, self.smtp_password)
            server.send_message(msg)
            server.quit()
            
            # 返回消息 ID（用时间戳模拟）
            return f"email_{datetime.now().timestamp()}"
