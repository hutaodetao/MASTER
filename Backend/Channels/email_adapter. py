class EmailWebhookParser:
    """邮件 Webhook 解析器"""
    
    def parse(self, payload: dict) -> Message | None:
        """解析邮件 Webhook
        
        支持格式:
        - SendGrid: payload['envelope'], payload['headers']
        - Mailgun: payload['sender'], payload['subject'], payload['body-plain']
        - 自定义: 其他格式
        """
        # SendGrid 格式
        if "envelope" in payload:
            return self._parse_sendgrid(payload)
        
        # Mailgun 格式
        if "sender" in payload and "body-plain" in payload:
            return self._parse_mailgun(payload)
        
        # 其他格式
        return self._parse_generic(payload)
    
    def _parse_sendgrid(self, payload: dict) -> Message:
        """解析 SendGrid Webhook"""
        envelope = json.loads(payload.get("envelope", "{}"))
        
        user = User(
            id=envelope.get("from", ""),
            name="",  # 需要从 header 获取
            platform="email",
        )
        
        return Message(
            id=payload.get("spam_score", ""),
            channel="email",
            user=user,
            content=payload.get("text", payload.get("html", "")),
            message_type=MessageType.TEXT,
            timestamp=datetime.now(),
        )
    
    def _parse_mailgun(self, payload: dict) -> Message:
        """解析 Mailgun Webhook"""
        user = User(
            id=payload.get("sender", ""),
            name=payload.get("sender", "").split("@")[0],
            platform="email",
        )
        
        content = payload.get("body-plain", "") or payload.get("body-html", "")
        
        return Message(
            id=payload.get("Message-Id", ""),
            channel="email",
            user=user,
            content=content,
            message_type=MessageType.TEXT,
            timestamp=datetime.now(),
            metadata={"subject": payload.get("subject", "")},
        )
    
    def _parse_generic(self, payload: dict) -> Message | None:
        """通用解析"""
        sender = payload.get("from") or payload.get("sender") or payload.get("email")
        content = payload.get("content") or payload.get("body") or payload.get("text")
        
        if not sender or not content:
            return None
        
        user = User(
            id=sender,
            name=sender.split("@")[0],
            platform="email",
        )
        
        return Message(
            id=payload.get("id", ""),
            channel="email",
            user=user,
            content=content,
            message_type=MessageType.TEXT,
            timestamp=datetime.now(),
        )