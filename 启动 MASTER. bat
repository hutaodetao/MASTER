@echo off
chcp 65001 >nul
title M. A. S. T. E. R.
mode con cols=80 lines=30

echo.
echo  ╔═══════════════════════════════════════════════════════╗
echo  ║           M.A.S.T.E.R. 启动中...                      ║
echo  ╚═══════════════════════════════════════════════════════╝
echo.

:: 激活虚拟环境（如果存在）
if exist "venv\Scripts\activate. bat" call venv\Scripts\activate.bat

:: 检查依赖
echo [*] 检查环境...
python -c "import qdrant_client" 2>nul
if errorlevel 1 (
    echo [!] 依赖未安装，请先运行 install. bat
    pause
    exit /b 1
)

echo [√] 环境检查通过

:: 启动后端
echo.
echo [*] 启动后端服务...
start "M.A.S.T.E.R. Backend" /min cmd /c "cd /d %~dp0 && python -m uvicorn backend.main:app --host 127.0.0.1 --port 8000"

:: 等待后端启动
timeout /t 3 /nobreak >nul

:: 启动前端
echo [*] 启动前端界面...
start "M.A.S.T.E.R. Frontend" /min cmd /c "cd /d %~dp0frontend && npm run dev"

:: 打开浏览器
echo [*] 打开浏览器...
timeout /t 2 /nobreak >nul
start http://localhost:3000

echo.
echo  ╔═══════════════════════════════════════════════════════╗
echo  ║           M.A.S.T.E.R. 已启动完成！                    ║
echo  ╚═══════════════════════════════════════════════════════╝
echo.
echo  后端地址: http://127.0.0.1:8000
echo  前端地址: http://localhost:3000
echo  API 文档: http://127.0.0.1:8000/docs
echo.
echo  按任意键关闭此窗口（服务仍在后台运行）
echo  停止服务请运行 stop. bat
echo.
pause >nul