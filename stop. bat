@echo off
chcp 65001 >nul
title 停止 M. A. S. T. E. R.
echo.
echo  ╔═══════════════════════════════════════════════════════╗
echo  ║           正在停止 M. A. S. T. E. R.                   ║
echo  ╚═══════════════════════════════════════════════════════╝
echo.
 
:: 停止 Python 进程
taskkill /F /FI "WINDOWTITLE eq M. A. S. T. E. R. Backend*" 2>nul
taskkill /F /FI "WINDOWTITLE eq M. A. S. T. E. R. Frontend*" 2>nul
taskkill /F /IM "python.exe" /FI "WINDOWTITLE eq M. A. S. T. E. R.*" 2>nul
taskkill /F /IM "node.exe" /FI "WINDOWTITLE eq M. A. S. T. E. R.*" 2>nul
 
:: 停止 Qdrant（如果是用脚本启动的）
taskkill /F /IM "qdrant.exe" 2>nul
 
echo [√] 服务已停止
echo.
pause